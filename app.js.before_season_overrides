function _fmLoadPosterImage(src){
  return new Promise(function(resolve, reject){
    if(!src) return reject(new Error('Missing image source'));
    const img = new Image();
    img.onload = function(){ resolve(img); };
    img.onerror = function(){ reject(new Error('Could not load image: ' + src)); };
    img.src = src;
  });
}

async function _fmDrawBestMapIconOnPoster(canvas){
  try{
    const info = canvas && canvas._fmBestMapIconInfo;
    if(!info) return;
    const src = _fmMapIconPathForLocation(info.location);
    if(!src) return;
    const img = await _fmLoadPosterImage(src);
    const ctx = canvas.getContext('2d');
    const pad = 4;
    ctx.save();
    ctx.fillStyle = 'rgba(255,255,255,.92)';
    ctx.strokeStyle = 'rgba(255,255,255,.16)';
    ctx.lineWidth = 1.2;
    ctx.beginPath();
    const r = 8, x = info.x, y = info.y, s = info.size;
    ctx.moveTo(x+r,y); ctx.arcTo(x+s,y,x+s,y+s,r); ctx.arcTo(x+s,y+s,x,y+s,r); ctx.arcTo(x,y+s,x,y,r); ctx.arcTo(x,y,x+s,y,r); ctx.closePath();
    ctx.fill(); ctx.stroke();
    ctx.drawImage(img, info.x + pad, info.y + pad, info.size - pad*2, info.size - pad*2);
    ctx.restore();
  }catch(err){
    // Icon is decorative. Never fail poster generation if an image is missing.
    console.warn('FishMetrics poster map icon skipped:', err);
  }
}

