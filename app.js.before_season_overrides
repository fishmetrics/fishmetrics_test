          type: (graphMode === 'GAIN' ? 'bar' : 'line'),
          data: {
            datasets: [{
              label: graphMode === 'GAIN' ? 'XP Gain' : 'XP',
              data: selectedData,
              fill: false,
              backgroundColor: graphMode === 'GAIN' ? 'rgba(255, 180, 0, 0.85)' : undefined,
              borderColor: graphMode === 'GAIN' ? 'rgba(255, 200, 0, 1)' : undefined,
              tension: graphMode === 'GAIN' ? 0 : 0.2,
              barPercentage: graphMode === 'GAIN' ? 0.6 : undefined,
              categoryPercentage: graphMode === 'GAIN' ? 0.8 : undefined
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            parsing: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  title(items){
                    const raw = items && items[0] && items[0].raw;
                    return raw && raw._date ? formatXPDate(raw._date) : 'Start';
                  },
                  label(item){
                    const raw = item && item.raw;
                    const prefix = graphMode === 'GAIN' ? 'Gain' : 'XP';
                    return `${prefix}: ${fmtInt(raw && raw.y != null ? raw.y : 0)}`;
                  }
                }
              }
            },
            scales: {
              x: {
                type: 'linear',
                grace: 0,
                afterBuildTicks(scale){
                  const uniq = Array.from(new Set(xValues)).sort((a, b) => a - b);
                  scale.ticks = uniq.map((value) => ({ value }));
                },
                ticks: {
                  autoSkip: false,
                  maxRotation: 0,
                  callback(value){
                    if(!baseDate) return value;
                    const labelDate = new Date(Date.parse(baseDate + 'T00:00:00') + (Number(value) * msPerDay));
                    if(!Number.isFinite(labelDate.getTime())) return '';
                    return labelDate.toLocaleDateString(undefined, { month:'short', day:'numeric' });
                  }
                }
              },
              y: { beginAtZero: graphMode === 'GAIN' }
            }
          }
        });
      }
    }catch(_){ }
  }


  function clampCatchValueNumber(value){
    if(value === '' || value === null || value === undefined) return null;
    const num = Number(value);
    if(!Number.isFinite(num)) return null;
    return Math.max(0, num);
  }

  function sanitizeCatchValueEntries(raw){
    const rows = [];
    try{
      (Array.isArray(raw) ? raw : []).forEach((entry) => {
        if(!entry || typeof entry !== 'object') return;
        const fish = String(entry.fish || '').trim().slice(0, 80);
        const date = normalizeISODate(entry.date) || todayISODate(); // kept internally only for stable save order; not shown in UI
        const weight = clampCatchValueNumber(entry.weight);
        const price = clampCatchValueNumber(entry.price);
        if(!fish || weight === null || price === null) return;
        rows.push({
          id: String(entry.id || ('cv_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2,7))),
          date,
          scope: String(entry.scope || '').toUpperCase() === 'VIP' ? 'VIP' : (String(entry.scope || '').toUpperCase() === 'MAIN' ? 'MAIN' : ''),
          location: String(entry.location || '').trim(),
          category: String(entry.category || '').trim(),
          fish,
          weight,
          price
        });
      });
    }catch(_){ }
    return rows.sort((a,b) => String(b.date || '').localeCompare(String(a.date || '')) || String(b.id || '').localeCompare(String(a.id || ''))).slice(0, 1000);
  }

  function getCatchValueFishOptions(){
    const seen = new Map();
    try{
      getPlannerRows().forEach((row) => {
        const name = toTitleCase(row.name || '');
        if(!name) return;
        const key = name.toLowerCase();
        if(!seen.has(key)) seen.set(key, name);
      });
    }catch(_){ }
    return Array.from(seen.values()).sort((a,b) => a.localeCompare(b));
  }

  function catchValueEntryKeyFromParts(scope, location, fish){
    return [String(scope || ''), String(location || ''), canonicalizeFishName(String(fish || ''))].join('|');
  }

  function catchValueEntryKey(row){
    return catchValueEntryKeyFromParts(row && row.scope, row && row.location, row && row.fish);
  }

  function catchValueRowStatsFor(entries, row){
    const key = keyForRow(row);
    const legacyFish = canonicalizeFishName(row && row.name);
    const scoped = sanitizeCatchValueEntries(entries).filter((entry) => {
      if(entry.scope || entry.location){
        return catchValueEntryKeyFromParts(entry.scope, entry.location, entry.fish) === key;
      }
      return canonicalizeFishName(entry.fish) === legacyFish;
    });
    const total = scoped.reduce((sum, entry) => sum + Number(entry.price || 0), 0);
    const avg = scoped.length ? total / scoped.length : 0;
    const best = scoped.reduce((max, entry) => Math.max(max, Number(entry.price || 0)), 0);
    const weightTotal = scoped.reduce((sum, entry) => sum + Number(entry.weight || 0), 0);
    const avgWeight = scoped.length ? weightTotal / scoped.length : 0;
    return { entries: scoped.length, avg, best, avgWeight };
  }
  function getCatchValueEntriesForRow(row){
    const key = keyForRow(row);
    const legacyFish = canonicalizeFishName(row && row.name);
    return sanitizeCatchValueEntries(plannerState.catchValueEntries || []).filter((entry) => {
      if(entry.scope || entry.location){
        return catchValueEntryKeyFromParts(entry.scope, entry.location, entry.fish) === key;
      }
      return canonicalizeFishName(entry.fish) === legacyFish;
    });
  }

