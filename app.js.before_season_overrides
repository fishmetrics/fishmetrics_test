  const colors = {
    bg:'#031021', panel:'#071d34', panel2:'#0a223e', text:'#f2f6ff', muted:'#a8badc', gold:'#e6be32', green:'#9fd66b',
    common:'#f2f6ff', rare:'#efe1a0', epic:'#e66aa6', legendary:'#a87ae6', mythic:'#d98a21',
    star1:'#e6be32', star2:'#e6be32', star3:'#e6be32', star4:'#e6be32', star5:'#e6be32',
    oos:'#6f7c91', line:'rgba(255,255,255,.08)', border:'rgba(230,190,50,.38)'
  };

  function roundRect(x,y,w,h,r,fill,stroke){
    ctx.beginPath(); ctx.moveTo(x+r,y); ctx.arcTo(x+w,y,x+w,y+h,r); ctx.arcTo(x+w,y+h,x,y+h,r); ctx.arcTo(x,y+h,x,y,r); ctx.arcTo(x,y,x+w,y,r); ctx.closePath();
    if(fill){ ctx.fillStyle=fill; ctx.fill(); }
    if(stroke){ ctx.strokeStyle=stroke; ctx.lineWidth=1.6; ctx.stroke(); }
  }
  function fitText(txt,x,y,maxW,font,fill){
    txt = String(txt == null ? '' : txt);
    ctx.font=font; ctx.fillStyle=fill || colors.text;
    if(ctx.measureText(txt).width <= maxW){ ctx.fillText(txt,x,y); return; }
    let t=txt;
    while(t.length>2 && ctx.measureText(t+'…').width>maxW) t=t.slice(0,-1);
    ctx.fillText(t+'…',x,y);
