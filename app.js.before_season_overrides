/* Season Screenshot Import Assistant — UI scaffold only */
(function(){
  function qs(id){ return document.getElementById(id); }
  function openSeasonImportModal(){
    populateSeasonImportMapOptions();
    setSeasonImportDefaultMapFromCurrentView();
    var backdrop = qs('seasonImportBackdrop');
