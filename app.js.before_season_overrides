  const cardPadTop = 96;
  const cardPadBottom = 22;
  mapData.forEach(function(m){ m.cardH = Math.max(170, cardPadTop + (m.rows.length * lineH) + cardPadBottom); });
  const rowHeights = [];
  for(let i=0; i<mapData.length; i+=cols){ rowHeights.push(Math.max.apply(null, mapData.slice(i,i+cols).map(function(m){ return m.cardH; }))); }
  const mapsHeight = rowHeights.reduce(function(a,b){ return a+b; },0) + gap * Math.max(0,rowHeights.length-1);
  const H = Math.max(isVip ? 1320 : 1900, headerH + mapsHeight + 118);

  const c = document.createElement('canvas');
