  function getCatchValueStats(entries){
    const rows = sanitizeCatchValueEntries(entries);
    const totalGold = rows.reduce((sum, row) => sum + Number(row.price || 0), 0);
    const avgSale = rows.length ? totalGold / rows.length : 0;
    const highest = rows.reduce((best, row) => !best || Number(row.price || 0) > Number(best.price || 0) ? row : best, null);
    const grouped = new Map();
    rows.forEach((row) => {
      const key = row.scope || row.location ? catchValueEntryKey(row) : canonicalizeFishName(row.fish);
      if(!grouped.has(key)) grouped.set(key, { fish: row.fish, scope: row.scope, location: row.location, entries: [], total: 0, best: 0, weightTotal: 0 });
      const item = grouped.get(key);
      item.entries.push(row);
      item.total += Number(row.price || 0);
      item.best = Math.max(item.best, Number(row.price || 0));
      item.weightTotal += Number(row.weight || 0);
    });
    const fishRows = Array.from(grouped.values()).map((item) => {
      const avg = item.entries.length ? item.total / item.entries.length : 0;
      const avgWeight = item.entries.length ? item.weightTotal / item.entries.length : 0;
      return { fish: item.fish, scope: item.scope, location: item.location, entries: item.entries.length, avg, best: item.best, avgWeight };
    }).sort((a,b) => b.avg - a.avg || String(a.fish || '').localeCompare(String(b.fish || '')));
    const bestAverage = fishRows[0] || null;
    return { rows, totalGold, avgSale, highest, bestAverage, fishRows };
  }

