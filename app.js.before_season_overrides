  function closeSeasonImportModal(){
    var backdrop = qs('seasonImportBackdrop');
    if(!backdrop) return;
    backdrop.classList.remove('show');
    backdrop.setAttribute('aria-hidden','true');
  }
  function refreshSeasonImportFiles(){
    var input = qs('seasonImportFiles');
    var list = qs('seasonImportFileList');
    var preview = qs('seasonImportPreview');
    if(!input || !list) return;
    var files = Array.prototype.slice.call(input.files || []);
    if(!files.length){
      list.textContent = 'No screenshots selected.';
      if(preview) preview.disabled = true;
      resetSeasonImportPreview();
      return;
    }
    list.innerHTML = files.map(function(f){
      return '<div>• ' + escapeSeasonImportText(f.name || 'Screenshot') + '</div>';
    }).join('');
    if(preview) preview.disabled = false;
    resetSeasonImportPreview();
  }
  function escapeSeasonImportText(value){
    return String(value == null ? '' : value).replace(/[&<>"]/g, function(ch){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[ch] || ch); });
  }
  function resetSeasonImportPreview(){
    var panel = qs('seasonImportPreviewPanel');
    var rows = qs('seasonImportPreviewRows');
    var status = qs('seasonImportPreviewStatus');
    if(panel) panel.hidden = true;
    if(status) status.textContent = 'OCR preview not run yet';
    if(rows){
      rows.innerHTML = '<tr><td colspan="3">Choose screenshots, then preview them here.</td></tr>';
    }
  }
  function seasonImportNormalizeName(value){
    return String(value || '').toLowerCase().replace(/&/g,'and').replace(/[^a-z0-9]/g,'');
  }

  function getSeasonImportScopeForMap(mapName){
    try{
      if(typeof LOCATIONS_VIP !== 'undefined' && LOCATIONS_VIP && LOCATIONS_VIP[mapName]) return 'VIP';
      if(typeof isVipModeActive === 'function' && isVipModeActive()) return 'VIP';
    }catch(_){ }
    return 'MAIN';
  }

  function getSeasonImportLocationsForScope(scope){
    var isVip = String(scope || '').toUpperCase() === 'VIP';
    try{
      return isVip
        ? ((typeof LOCATIONS_VIP !== 'undefined' && LOCATIONS_VIP) ? LOCATIONS_VIP : {})
        : ((typeof LOCATIONS !== 'undefined' && LOCATIONS) ? LOCATIONS : {});
    }catch(_){ return {}; }
  }

  function getSeasonImportFishList(mapName){
    try{
      var locs = getSeasonImportLocationsForScope(getSeasonImportScopeForMap(mapName));
      var source = (locs && locs[mapName]) ? locs[mapName] : [];
      return source.map(function(f){
        return {
          name: f.name,
          label: (typeof toTitleCase === 'function') ? toTitleCase(f.name) : f.name,
          fish: f,
          norm: seasonImportNormalizeName(f.name)
        };
      });
    }catch(_){ return []; }
  }

  function loadSeasonImportOcr(){
    if(window.Tesseract) return Promise.resolve(window.Tesseract);
    if(window.__fmSeasonImportTesseractPromise) return window.__fmSeasonImportTesseractPromise;
    window.__fmSeasonImportTesseractPromise = new Promise(function(resolve, reject){
      var script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js';
      script.async = true;
      script.onload = function(){ window.Tesseract ? resolve(window.Tesseract) : reject(new Error('OCR library did not load.')); };
      script.onerror = function(){ reject(new Error('Could not load OCR library.')); };
      document.head.appendChild(script);
    });
    return window.__fmSeasonImportTesseractPromise;
  }

  function loadSeasonImportImage(file){
    return new Promise(function(resolve, reject){
      var img = new Image();
      var url = URL.createObjectURL(file);
      img.onload = function(){ URL.revokeObjectURL(url); resolve(img); };
      img.onerror = function(){ URL.revokeObjectURL(url); reject(new Error('Could not read image.')); };
      img.src = url;
    });
  }

  function makeSeasonImportOcrCanvas(img){
    var w = img.naturalWidth || img.width;
    var h = img.naturalHeight || img.height;
    var sx = Math.round(w * 0.40);
    var sy = Math.round(h * 0.04);
    var sw = Math.round(w * 0.43);
    var sh = Math.round(h * 0.86);
    var scale = 2;
    var canvas = document.createElement('canvas');
    canvas.width = sw * scale;
    canvas.height = sh * scale;
    var ctx = canvas.getContext('2d', { willReadFrequently: true });
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, sx, sy, sw, sh, 0, 0, canvas.width, canvas.height);
    return canvas;
  }


  function makeSeasonImportFirstRowPointsCanvas(img){
    // Targeted helper for the first visible row's pink points value.
    // The close button and star glyphs can pollute line OCR, especially on Bluefish.
    var w = img.naturalWidth || img.width;
    var h = img.naturalHeight || img.height;
    var sx = Math.round(w * 0.735);
    var sy = Math.round(h * 0.085);
    var sw = Math.round(w * 0.065);
    var sh = Math.round(h * 0.090);
    var scale = 4;
    var canvas = document.createElement('canvas');
    canvas.width = sw * scale;
    canvas.height = sh * scale;
    var ctx = canvas.getContext('2d', { willReadFrequently: true });
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, sx, sy, sw, sh, 0, 0, canvas.width, canvas.height);
    return canvas;
  }

  function seasonImportApplyTargetedBluefishFix(rows, points){
    if(!Array.isArray(rows) || !Number.isFinite(points)) return rows;
    for(var i=0; i<rows.length; i++){
      if(rows[i] && seasonImportNormalizeName(rows[i].fish) === 'bluefish'){
        rows[i].points = points;
        rows[i].status = 'Detected · first-row points verified';
        break;
      }
    }
    return rows;
  }

  function seasonImportParseDigitsOnlyPoints(text, fish){
    var raw = String(text || '').replace(/[^0-9]/g, '');
    if(!raw) return null;
    var mm = seasonImportPointRange(fish);
    var maxP = Number(mm && mm.maxP) || 10000;
    var minP = Number(mm && mm.minP) || 0;
    var floor = Math.max(0, minP - 20);
    var candidates = [];
    for(var len=3; len<=5; len++){
      if(raw.length < len) continue;
      candidates.push(raw.slice(0, len));
      candidates.push(raw.slice(-len));
      for(var start=1; start<=raw.length-len-1; start++) candidates.push(raw.slice(start, start + len));
    }
    for(var i=0; i<candidates.length; i++){
      var n = parseInt(candidates[i], 10);
      if(n === 0 || (n >= floor && n <= maxP)) return n;
    }
    return seasonImportNormalizePointCandidate(parseInt(raw, 10), fish, raw);
  }

  function seasonImportFindFishInLine(line, fishList){
    var normLine = seasonImportNormalizeName(line);
    if(!normLine) return null;
    var best = null;
    for(var i=0; i<fishList.length; i++){
      var item = fishList[i];
      if(item.norm && normLine.indexOf(item.norm) !== -1){
        if(!best || item.norm.length > best.norm.length) best = item;
      }
    }
    return best;
  }

  function seasonImportPointRange(fish){
    try{
      if(typeof _minMaxPointsForFish === 'function') return _minMaxPointsForFish(fish);
    }catch(_){ }
    return { minP: 0, maxP: 10000 };
  }

  function seasonImportNormalizePointCandidate(value, fish, rawDigits){
    if(!Number.isFinite(value)) return null;
    var mm = seasonImportPointRange(fish);
    var maxP = Number(mm && mm.maxP) || 10000;
    var minP = Number(mm && mm.minP) || 0;
    var floor = Math.max(0, minP - 20);
    var n = Math.round(value);
    if(n === 0) return 0;
    if(n >= floor && n <= maxP) return n;

    // OCR often attaches the pink P/badge or nearby noise to the point value
    // (example: Bluefish 492 can become 4929). Try clean substrings before giving up.
    var digits = String(rawDigits || String(n).replace(/\D/g, ''));
    var desiredLengths = maxP < 1000 ? [3, 4] : [4, 3, 5];
    for(var dl=0; dl<desiredLengths.length; dl++){
      var len = desiredLengths[dl];
      if(digits.length < len) continue;
      var candidates = [];
      candidates.push(digits.slice(0, len));
      candidates.push(digits.slice(-len));
      for(var start=1; start<=digits.length-len-1; start++) candidates.push(digits.slice(start, start + len));
      for(var ci=0; ci<candidates.length; ci++){
        var c = parseInt(candidates[ci], 10);
        if(c === 0 || (c >= floor && c <= maxP)) return c;
      }
    }

    if(n > maxP && n % 10 === 0){
      var trimmed = Math.round(n / 10);
      if(trimmed >= floor && trimmed <= maxP) return trimmed;
    }
    return n;
  }

  function seasonImportParsePointsFromLine(line, fish){
    var candidates = [];
    var rawMatches = String(line || '').match(/\d[\d\s,.]*/g) || [];
    rawMatches.forEach(function(raw){
      var compact = String(raw || '').trim();
      if(!compact) return;
      if(/^\d+[,.]\d+$/.test(compact)){
        candidates.push(parseFloat(compact.replace(',', '.')));
      }
      var digits = compact.replace(/\D/g, '');
      if(digits !== '') candidates.push({ value: parseInt(digits, 10), rawDigits: digits });
    });
    if(!candidates.length) return null;
    var mm = seasonImportPointRange(fish);
    var maxP = Number(mm && mm.maxP) || 10000;
    var minP = Number(mm && mm.minP) || 0;
    var normalized = candidates.map(function(c){
      if(c && typeof c === 'object') return seasonImportNormalizePointCandidate(c.value, fish, c.rawDigits);
      return seasonImportNormalizePointCandidate(c, fish);
    }).filter(function(c){ return c !== null; });
    var inRange = normalized.filter(function(c){ return c === 0 || (c >= Math.max(0, minP - 20) && c <= maxP); });
    if(inRange.length) return inRange[inRange.length - 1];
    return normalized.length ? normalized[normalized.length - 1] : null;
  }

  function parseSeasonImportText(text, mapName){
    var fishList = getSeasonImportFishList(mapName);
    var found = [];
    var seen = {};
    var lines = String(text || '').split(/\r?\n/).map(function(line){ return line.trim(); }).filter(Boolean);
    lines.forEach(function(line){
      var match = seasonImportFindFishInLine(line, fishList);
      if(!match) return;
      var pts = seasonImportParsePointsFromLine(line, match.fish);
      var assumedZero = false;
      if(pts == null){
        pts = 0;
        assumedZero = true;
      }
      var row = {
        fish: match.name,
        label: match.label,
        points: pts,
        status: assumedZero ? 'Detected · points assumed 0' : 'Detected',
        sourceLine: line
      };
      if(seen[match.name] != null){
        found[seen[match.name]] = row;
      }else{
        seen[match.name] = found.length;
        found.push(row);
      }
    });
    return found;
  }

  function mergeSeasonImportRows(existing, incoming){
    // Preserve screenshot/OCR order. If a fish is seen again in a later screenshot,
    // update its points/status but keep its original visible position.
    var out = (existing || []).slice();
    var index = {};
    out.forEach(function(row, i){ if(row && row.fish) index[row.fish] = i; });
    (incoming || []).forEach(function(row){
      if(!row || !row.fish) return;
      if(index[row.fish] != null){
        out[index[row.fish]] = row;
      }else{
        index[row.fish] = out.length;
        out.push(row);
      }
    });
    return out;
  }

  async function showSeasonImportPreviewShell(){
    var filesInput = qs('seasonImportFiles');
    var mapSelect = qs('seasonImportMap');
    var panel = qs('seasonImportPreviewPanel');
    var rows = qs('seasonImportPreviewRows');
    var status = qs('seasonImportPreviewStatus');
    var previewBtn = qs('seasonImportPreview');
    var files = Array.prototype.slice.call((filesInput && filesInput.files) || []);
    var mapName = mapSelect && mapSelect.value ? mapSelect.value : 'Paradise Island';
    if(!files.length) return;
    if(panel) panel.hidden = false;
    if(rows) rows.innerHTML = '<tr><td colspan="3">Reading screenshots…</td></tr>';
    if(status) status.textContent = 'Loading OCR…';
    if(previewBtn){ previewBtn.disabled = true; previewBtn.textContent = 'Reading…'; }
    try{
      var Tesseract = await loadSeasonImportOcr();
      var allRows = [];
      for(var i=0; i<files.length; i++){
        if(status) status.textContent = 'Reading ' + (i + 1) + ' of ' + files.length + '…';
        var img = await loadSeasonImportImage(files[i]);
        var canvas = makeSeasonImportOcrCanvas(img);
        var result = await Tesseract.recognize(canvas, 'eng', {
          tessedit_pageseg_mode: '6',
          logger: function(m){
            if(status && m && m.status === 'recognizing text' && Number.isFinite(m.progress)){
              status.textContent = 'Reading ' + (i + 1) + ' of ' + files.length + ' · ' + Math.round(m.progress * 100) + '%';
            }
          }
        });
        var parsed = parseSeasonImportText(result && result.data ? result.data.text : '', mapName);

        // Paradise first row edge case: Bluefish sits next to the close icon,
        // so full-line OCR can still mangle its point value even when the
        // rest of the screenshot parses well. If Bluefish was detected in
        // this screenshot, run a tiny points-only OCR crop for that first row.
        if(mapName === 'Paradise Island' && parsed.some(function(r){ return r && seasonImportNormalizeName(r.fish) === 'bluefish'; })){
          try{
            var fishListForFix = getSeasonImportFishList(mapName);
            var bluefishItem = fishListForFix.find(function(item){ return item && seasonImportNormalizeName(item.name) === 'bluefish'; });
            var blueCanvas = makeSeasonImportFirstRowPointsCanvas(img);
            var blueResult = await Tesseract.recognize(blueCanvas, 'eng', {
              tessedit_char_whitelist: '0123456789',
              tessedit_pageseg_mode: '7'
            });
            var bluePts = seasonImportParseDigitsOnlyPoints(blueResult && blueResult.data ? blueResult.data.text : '', bluefishItem ? bluefishItem.fish : null);
            if(bluePts !== null) parsed = seasonImportApplyTargetedBluefishFix(parsed, bluePts);
          }catch(_){ }
        }

        allRows = mergeSeasonImportRows(allRows, parsed);
      }
      if(status) status.textContent = mapName + ' · ' + allRows.length + ' fish detected · review before import';
      if(rows){
        if(!allRows.length){
          var confirmBtnEmpty = qs('seasonImportConfirm');
          if(confirmBtnEmpty) confirmBtnEmpty.disabled = true;
          rows.innerHTML = '<tr><td colspan="3">No fish rows detected. Try a clearer screenshot or another crop.</td></tr>';
        }else{
          var confirmBtn = qs('seasonImportConfirm');
          if(confirmBtn) confirmBtn.disabled = false;
          rows.innerHTML = allRows.map(function(row){
            var safeFish = escapeSeasonImportText(row.fish);
            var safeLabel = escapeSeasonImportText(row.label);
            var safePoints = escapeSeasonImportText(row.points);
            return '<tr data-fish="' + safeFish + '">' +
              '<td>' + safeLabel + '</td>' +
              '<td><input class="season-import-points-input" type="number" inputmode="numeric" min="0" step="1" value="' + safePoints + '" aria-label="Imported points for ' + safeLabel + '" /></td>' +
              '<td>' + escapeSeasonImportText(row.status) + ' · editable</td>' +
            '</tr>';
          }).join('');
        }
      }
    }catch(err){
      if(status) status.textContent = 'OCR failed';
      var confirmBtnFail = qs('seasonImportConfirm');
      if(confirmBtnFail) confirmBtnFail.disabled = true;
      if(rows) rows.innerHTML = '<tr><td colspan="3">Could not read screenshots. ' + escapeSeasonImportText(err && err.message ? err.message : '') + '</td></tr>';
    }finally{
      if(previewBtn){ previewBtn.disabled = false; previewBtn.textContent = 'Preview Import'; }
    }
  }


  function seasonImportFindFishObject(mapName, fishName){
    var fishList = getSeasonImportFishList(mapName);
    var wanted = seasonImportNormalizeName(fishName);
    for(var i=0; i<fishList.length; i++){
      if(seasonImportNormalizeName(fishList[i].name) === wanted) return fishList[i].fish;
    }
    return null;
  }

  function collectSeasonImportPreviewRows(){
    var tbody = qs('seasonImportPreviewRows');
    var out = [];
    if(!tbody) return out;
    Array.prototype.slice.call(tbody.querySelectorAll('tr[data-fish]')).forEach(function(tr){
      var fishName = tr.getAttribute('data-fish') || '';
      var input = tr.querySelector('.season-import-points-input');
      var raw = input ? String(input.value || '').trim() : '';
      var pts = raw === '' ? NaN : Number(raw);
      out.push({ row: tr, fish: fishName, points: pts, input: input });
    });
    return out;
  }

  function setSeasonImportLogLocation(mapName){
    try{
      var loc = qs('locationSelect') || (typeof locationSelect !== 'undefined' ? locationSelect : null);
      if(!loc) return;
      var hasOption = Array.prototype.slice.call(loc.options || []).some(function(opt){ return opt && opt.value === mapName; });
      if(!hasOption) return;
      loc.value = mapName;
    }catch(_){ }
  }

  function showSeasonImportCompleteModal(mapName, updated, cleared){
    var backdrop = qs('seasonImportCompleteBackdrop');
    var body = qs('seasonImportCompleteBody');
    var ok = qs('seasonImportCompleteOk');
    var text = mapName + ' imported. ' + updated + ' fish updated' + (cleared ? ' · ' + cleared + ' cleared' : '') + '.';
    if(!backdrop || !body || !ok){
      try{ console.log('Season import complete:', text); }catch(_){ }
      return;
    }
    body.innerHTML = '<strong>' + escapeSeasonImportText(mapName) + '</strong> imported successfully.<br>' +
      escapeSeasonImportText(String(updated)) + ' fish updated' +
      (cleared ? ' · ' + escapeSeasonImportText(String(cleared)) + ' cleared' : '') +
      '.<br><br>Log Records has been switched to this map.';
    backdrop.classList.add('show');
    backdrop.setAttribute('aria-hidden','false');
    var cleanup = function(){
      backdrop.classList.remove('show');
      backdrop.setAttribute('aria-hidden','true');
      ok.onclick = null;
      backdrop.onclick = null;
    };
    ok.onclick = cleanup;
    backdrop.onclick = function(e){ if(e.target === backdrop) cleanup(); };
  }

  async function confirmSeasonImport(){
    var mapSelect = qs('seasonImportMap');
    var mapName = mapSelect && mapSelect.value ? mapSelect.value : 'Paradise Island';
    var importScope = getSeasonImportScopeForMap(mapName);
    var isVipImport = importScope === 'VIP';
    var rows = collectSeasonImportPreviewRows();
    var status = qs('seasonImportPreviewStatus');
    var confirmBtn = qs('seasonImportConfirm');
    if(!rows.length){
      if(status) status.textContent = 'Preview first, then confirm import.';
      return;
    }

    var valid = [];
    var invalid = [];
    rows.forEach(function(r){
      var fish = seasonImportFindFishObject(mapName, r.fish);
      var pts = Number(r.points);
      if(!fish || !Number.isFinite(pts) || pts < 0 || Math.round(pts) !== pts){
        invalid.push(r);
        if(r.input) r.input.classList.add('invalid');
        return;
      }
      var mm = seasonImportPointRange(fish);
      if(pts !== 0 && (pts < Number(mm.minP || 0) || pts > Number(mm.maxP || 10000))){
        invalid.push(r);
        if(r.input) r.input.classList.add('invalid');
        return;
      }
      if(r.input) r.input.classList.remove('invalid');
      valid.push({ fish: fish, fishName: r.fish, points: pts });
    });
    if(invalid.length){
      if(status) status.textContent = invalid.length + ' row(s) need valid whole-number points before import.';
      return;
    }

    if(confirmBtn){ confirmBtn.disabled = true; confirmBtn.textContent = 'Importing…'; }
    try{
      if(isVipImport){
        if(!seasonRecordsByLocation_vip || typeof seasonRecordsByLocation_vip !== 'object') seasonRecordsByLocation_vip = {};
      }else{
        if(!seasonRecordsByLocation_main || typeof seasonRecordsByLocation_main !== 'object') seasonRecordsByLocation_main = {};
      }
      var targetSeasonStore = isVipImport ? seasonRecordsByLocation_vip : seasonRecordsByLocation_main;
      var mapRecords = Object.assign({}, targetSeasonStore[mapName] || {});
      var updated = 0;
      var cleared = 0;
      valid.forEach(function(item){
        var key = canonicalizeFishName(item.fish.name);
        if(item.points === 0){
          if(Object.prototype.hasOwnProperty.call(mapRecords, key)) cleared++;
          delete mapRecords[key];
          return;
        }
        var wStr = storedWeightStringForPoints(item.points, item.fish);
        mapRecords[key] = wStr;
        updated++;
      });
      targetSeasonStore[mapName] = mapRecords;
      if(isVipImport){
        seasonRecordsByLocation_vip = targetSeasonStore;
        if(typeof isVipModeActive === 'function' && isVipModeActive()) seasonRecordsByLocation = seasonRecordsByLocation_vip;
      }else{
        seasonRecordsByLocation_main = targetSeasonStore;
        if(!(typeof isVipModeActive === 'function' && isVipModeActive())) seasonRecordsByLocation = seasonRecordsByLocation_main;
      }
      if(typeof idbSaveAllSeasonRecordsToStore === 'function'){
        await idbSaveAllSeasonRecordsToStore(isVipImport ? IDB_STORE_SEASON_VIP : IDB_STORE_SEASON, targetSeasonStore || {});
      }else if(!isVipImport){
        await idbSaveAllSeasonRecords(seasonRecordsByLocation_main || {});
      }

      setSeasonImportLogLocation(mapName);
      try{ if(typeof renderTable === 'function') renderTable(); }catch(_){ }
      try{ if(typeof recomputeFromDOM === 'function') recomputeFromDOM(); }catch(_){ }
      try{ if(typeof updateDashboard === 'function') updateDashboard(); }catch(_){ }
      try{ if(typeof updateSeasonProgress === 'function') updateSeasonProgress(); }catch(_){ }
      try{ if(typeof updateSeasonUncaughtCount === 'function') updateSeasonUncaughtCount(); }catch(_){ }
      try{ if(typeof renderCareerTargets === 'function') renderCareerTargets(); }catch(_){ }

      if(status) status.textContent = mapName + ' imported · ' + updated + ' updated' + (cleared ? ' · ' + cleared + ' cleared' : '');
      closeSeasonImportModal();
      showSeasonImportCompleteModal(mapName, updated, cleared);
    }catch(err){
      if(status) status.textContent = 'Import failed' + (err && err.message ? ': ' + err.message : '');
    }finally{
      if(confirmBtn){ confirmBtn.disabled = false; confirmBtn.textContent = 'Confirm Import'; }
    }
  }


  function getSeasonImportMapsForActiveMode(){
    var useVip = false;
    try{ useVip = (typeof isVipModeActive === 'function' && isVipModeActive()); }catch(_){ useVip = false; }
    try{
      if(useVip){
        if(typeof VIP_LOCATION_ORDER !== 'undefined' && Array.isArray(VIP_LOCATION_ORDER)){
          return VIP_LOCATION_ORDER.filter(function(name){ return !!(LOCATIONS_VIP && LOCATIONS_VIP[name]); });
        }
        if(typeof LOCATIONS_VIP !== 'undefined' && LOCATIONS_VIP) return Object.keys(LOCATIONS_VIP);
      }
      if(typeof LOCATION_ORDER !== 'undefined' && Array.isArray(LOCATION_ORDER)){
        return LOCATION_ORDER.filter(function(name){ return !!(LOCATIONS && LOCATIONS[name]); });
      }
      if(typeof LOCATIONS !== 'undefined' && LOCATIONS) return Object.keys(LOCATIONS);
    }catch(_){ }
    return ['Paradise Island'];
  }

  function populateSeasonImportMapOptions(){
    var mapSelect = qs('seasonImportMap');
    if(!mapSelect) return;
    var useVip = false;
    try{ useVip = (typeof isVipModeActive === 'function' && isVipModeActive()); }catch(_){ useVip = false; }
    var modeKey = useVip ? 'VIP' : 'MAIN';
    var maps = getSeasonImportMapsForActiveMode();
    var current = mapSelect.value || (useVip ? (maps[0] || '') : 'Paradise Island');
    if(mapSelect.__fmPopulatedMode === modeKey && mapSelect.options && mapSelect.options.length === maps.length) return;
    mapSelect.innerHTML = maps.map(function(name){
      return '<option value="' + escapeSeasonImportText(name) + '">' + escapeSeasonImportText(name) + '</option>';
    }).join('');
    if(maps.indexOf(current) !== -1) mapSelect.value = current;
    else if(!useVip && maps.indexOf('Paradise Island') !== -1) mapSelect.value = 'Paradise Island';
    else if(maps.length) mapSelect.value = maps[0];
    mapSelect.__fmPopulatedMode = modeKey;
  }

  function setSeasonImportDefaultMapFromCurrentView(){
    var mapSelect = qs('seasonImportMap');
    if(!mapSelect) return;
    try{
      var loc = qs('locationSelect') || (typeof locationSelect !== 'undefined' ? locationSelect : null);
      var current = loc && loc.value ? loc.value : '';
      var maps = getSeasonImportMapsForActiveMode();
      if(current && current !== '__ALL__' && current !== 'All Locations' && maps.indexOf(current) !== -1){
        mapSelect.value = current;
      }
    }catch(_){ }
  }
  function initSeasonImportUi(){
    var btn = qs('seasonImportBtn');
    if(btn && !btn.__bound){
      btn.__bound = true;
      btn.addEventListener('click', openSeasonImportModal);
    }
    var cancel = qs('seasonImportCancel');
    if(cancel && !cancel.__bound){
      cancel.__bound = true;
      cancel.addEventListener('click', closeSeasonImportModal);
    }
    var backdrop = qs('seasonImportBackdrop');
    if(backdrop && !backdrop.__bound){
      backdrop.__bound = true;
      backdrop.addEventListener('click', function(e){ if(e.target === backdrop) closeSeasonImportModal(); });
    }
    populateSeasonImportMapOptions();
    var mapSelect = qs('seasonImportMap');
    if(mapSelect && !mapSelect.__bound){
      mapSelect.__bound = true;
      mapSelect.addEventListener('change', function(){
        resetSeasonImportPreview();
        var confirm = qs('seasonImportConfirm');
        if(confirm) confirm.disabled = true;
      });
    }
    var files = qs('seasonImportFiles');
    if(files && !files.__bound){
      files.__bound = true;
      files.addEventListener('change', refreshSeasonImportFiles);
    }
    var preview = qs('seasonImportPreview');
    if(preview && !preview.__bound){
      preview.__bound = true;
      preview.addEventListener('click', function(){
        showSeasonImportPreviewShell();
      });
    }
    var confirm = qs('seasonImportConfirm');
    if(confirm && !confirm.__bound){
      confirm.__bound = true;
      confirm.addEventListener('click', confirmSeasonImport);
    }
    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape') closeSeasonImportModal();
    });
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initSeasonImportUi);
  else initSeasonImportUi();
})();
